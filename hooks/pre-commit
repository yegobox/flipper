#!/bin/bash
# Bump app pubspec versions only for apps affected by this commit.
# This avoids version conflicts when multiple people commit on the same branch.
#
# Flutter `version:`  → Major.Minor.Patch+Build
#   For apps/flipper (Store): Minor +1 and Patch reset to 0 (stays in step with MSIX).
#   For other apps: Patch and Build +1 (unchanged behaviour).
# MSIX `msix_version:` → Major.Minor.0.0 with Minor +1 each bump
#   (Partner Center: 1.185.0.0 → 1.186.0.0). Package-only commits that ship
#   inside apps/flipper still trigger this bump.
LOCKFILE=/tmp/pre-commit.lock

cleanup() {
  rm -f "$LOCKFILE"
}
trap cleanup EXIT

if [ -d ".git/rebase-merge" ] || [ -d ".git/rebase-apply" ]; then
  echo "Rebase in progress, skipping version increment..."
  exit 0
fi

if [ -f "$LOCKFILE" ]; then
  echo "Script is already running. Exiting..."
  exit 1
fi

touch "$LOCKFILE"

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT" || exit 1

STAGED_FILES=$(git diff --cached --name-only)

app_has_staged_changes() {
  local app_rel="${1#./}"
  local file
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    [[ "$file" == "$app_rel/"* ]] && return 0
  done <<< "$STAGED_FILES"
  return 1
}

# Windows Store MSIX is built from apps/flipper + workspace packages. Package-
# only commits still change the binary, so bump Flipper's version + msix_version.
flipper_msix_has_staged_changes() {
  local file
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    case "$file" in
      apps/flipper/*) return 0 ;;
      packages/flipper_*/*) return 0 ;;
      packages/supabase_models/*) return 0 ;;
      packages/flipper_design_system/*) return 0 ;;
      packages/flipper_localize/*) return 0 ;;
      packages/flipper_ui/*) return 0 ;;
      packages/flipper_analytics/*) return 0 ;;
      melos.yaml) return 0 ;;
    esac
  done <<< "$STAGED_FILES"
  return 1
}

# Configuration: Add folders to exclude (space-separated list)
EXCLUDE_FOLDERS=("node_modules" "build" "test" "packages" "open-sources")

EXCLUDE_PATTERN=""
for folder in "${EXCLUDE_FOLDERS[@]}"; do
  EXCLUDE_PATTERN+=" ! -path \"*/$folder/*\""
done

OS=$(uname)
if [[ "$OS" == "Darwin" ]]; then
  SED_INPLACE() {
    sed -i .bak "$1" "$2" && rm -f "$2.bak"
  }
else
  SED_INPLACE() {
    sed -i "$1" "$2"
  }
fi

# Read active (uncommented) msix_version: value from a pubspec.
read_msix_version() {
  awk '/^[[:space:]]*msix_version:[[:space:]]*/ && $1 !~ /^#/ {
    # Field 1 is "msix_version:", field 2 is the version.
    print $2
    exit
  }' "$1"
}

# Bump MSIX identity for Partner Center: Major.Minor.0.0 with Minor +1.
# Example: 1.185.0.0 → 1.186.0.0 (Build/Revision stay 0).
# Cap at 65535 (MSIX limit) with rollover into Major.
bump_msix_version() {
  local current="$1"

  if [[ ! "$current" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]; then
    echo "Invalid msix_version format: $current" >&2
    return 1
  fi

  local major="${BASH_REMATCH[1]}"
  local minor="${BASH_REMATCH[2]}"

  minor=$((minor + 1))
  if (( minor > 65535 )); then
    minor=0
    major=$((major + 1))
  fi

  echo "$major.$minor.0.0"
}

eval "find . -type f -name \"pubspec.yaml\" $EXCLUDE_PATTERN" | while read -r PUBSPEC_PATH; do
  APP_DIR=$(dirname "$PUBSPEC_PATH")
  APP_REL="${APP_DIR#./}"

  should_bump=false
  is_flipper_windows=false
  if [[ "$APP_REL" == "apps/flipper" ]]; then
    is_flipper_windows=true
    if flipper_msix_has_staged_changes; then
      should_bump=true
    fi
  elif app_has_staged_changes "$APP_DIR"; then
    should_bump=true
  fi

  if [[ "$should_bump" != true ]]; then
    echo "Skipping $APP_DIR/pubspec.yaml (no staged changes affecting this app)"
    continue
  fi

  cd "$APP_DIR" || continue

  echo "Processing $APP_DIR/pubspec.yaml"

  version_line=$(grep "^version: " pubspec.yaml)
  if [[ -z "$version_line" ]]; then
    echo "No version field found in $APP_DIR/pubspec.yaml"
    cd - > /dev/null
    continue
  fi

  version=$(echo "$version_line" | awk '{print $2}')

  if [[ "$version" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)(\+([0-9]+))?$ ]]; then
    major="${BASH_REMATCH[1]}"
    minor="${BASH_REMATCH[2]}"
    patch="${BASH_REMATCH[3]}"
    build_number="${BASH_REMATCH[5]}"

    if [[ -z "$build_number" ]]; then
      build_number=1
    else
      build_number=$((build_number + 1))
    fi

    if [[ "$is_flipper_windows" == true ]]; then
      # Keep Flutter Major.Minor aligned with MSIX (1.185.x → 1.186.0+build).
      minor=$((minor + 1))
      if (( minor > 65535 )); then
        minor=0
        major=$((major + 1))
      fi
      patch=0
    else
      patch=$((patch + 1))
    fi

    base_version="$major.$minor.$patch"
    new_version="$base_version+$build_number"
  else
    echo "Invalid version format in $APP_DIR/pubspec.yaml: $version"
    cd - > /dev/null
    continue
  fi

  SED_INPLACE "s|$version_line|version: $new_version|" pubspec.yaml
  echo "  version: $version → $new_version"
  git add pubspec.yaml

  msix_version=$(read_msix_version pubspec.yaml)
  if [[ -n "$msix_version" ]]; then
    if new_msix_version=$(bump_msix_version "$msix_version"); then
      # Replace only the active (uncommented) msix_version line.
      SED_INPLACE "s|^[[:space:]]*msix_version:[[:space:]]*$msix_version|  msix_version: $new_msix_version|" pubspec.yaml
      echo "  msix_version: $msix_version → $new_msix_version"
      git add pubspec.yaml
    else
      echo "Invalid msix_version format in $APP_DIR/pubspec.yaml: $msix_version"
    fi
  fi

  cd - > /dev/null
done

exit 0
