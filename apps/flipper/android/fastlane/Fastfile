default_platform(:android)

def shorebird_cmd
  env_bin = ENV['SHOREBIRD_BIN']
  return env_bin if env_bin && !env_bin.empty? && File.executable?(env_bin)

  xdg = ENV['XDG_CONFIG_HOME']
  if xdg && !xdg.empty?
    xdg_bin = File.join(xdg, 'shorebird', 'bin', 'shorebird')
    return xdg_bin if File.executable?(xdg_bin)
  end

  home_bin = File.join(ENV['HOME'] || Dir.home, '.shorebird', 'bin', 'shorebird')
  return home_bin if File.executable?(home_bin)

  which = `command -v shorebird 2>/dev/null`.strip
  return which unless which.empty?

  UI.user_error!(
    'shorebird CLI not found. Install it in CI or locally: https://docs.shorebird.dev'
  )
end

def build_release_bundle
  if ENV['USE_SHOREBIRD'] == 'true'
    if ENV['SHOREBIRD_TOKEN'].to_s.strip.empty?
      UI.user_error!(
        'SHOREBIRD_TOKEN is not set. Create an API key at https://console.shorebird.dev ' \
        '(Account → API Keys) and add it to GitHub Actions secrets.'
      )
    end

    flutter_flag = ''
    flutter_version = ENV['FLUTTER_VERSION'].to_s.strip
    flutter_flag = " --flutter-version=#{flutter_version}" unless flutter_version.empty?

    sh "cd .. && #{shorebird_cmd} release android -v#{flutter_flag} -- --no-android-gradle-daemon"
  else
    sh "cd .. && flutter build appbundle -- --no-android-gradle-daemon"
  end
end

platform :android do

  desc "Submit a new internal build to Google Play"
  lane :internal do 
  
    build_release_bundle

    upload_to_play_store(
      package_name: 'rw.flipper',
      track: 'internal',
      aab: '../build/app/outputs/bundle/release/app-release.aab',
      json_key_data: ENV['PLAY_STORE_CONFIG_JSON'],
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true
      )
  end
  desc "Promote beta track to prod"
  lane :promote_to_production do
    upload_to_play_store(
      track: 'beta',
      package_name: 'rw.flipper',
      track_promote_to: 'production',
      skip_upload_changelogs: true,
      json_key_data: ENV['PLAY_STORE_CONFIG_JSON'],
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true
      )
  end

  desc "Submit a new beta build to Google Play"
  lane :beta do
    build_release_bundle

    upload_to_play_store(
      track: 'beta',
      package_name: 'rw.flipper',
      aab: '../build/app/outputs/bundle/release/app-release.aab',
      json_key_data: ENV['PLAY_STORE_CONFIG_JSON'],
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end

  desc "Submit a new production build to Google Play"
  lane :production do
    build_release_bundle

    upload_to_play_store(
      track: 'production',
      package_name: 'rw.flipper',
      aab: '../build/app/outputs/bundle/release/app-release.aab',
      json_key_data: ENV['PLAY_STORE_CONFIG_JSON'],
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
